# Remindarr — environment template.
# Copy to `.env` and fill in the values. `.env` is gitignored.
# Defaults shown in parentheses are what the server falls back to if the var is unset.

# ── Required ─────────────────────────────────────────────────────────────────
# TMDB API key — get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Core ────────────────────────────────────────────────────────────────────
# PORT=3000
# DB_PATH=./remindarr.db
# LOG_LEVEL=info                 # debug | info | warn | error

# Base URL your deployment is served from — required for passkeys, OIDC callbacks, and push subjects.
# Example: https://remindarr.example.com
BASE_URL=

# Comma-separated allowed origins for CORS. Leave empty to disable CORS headers (same-origin only).
# CORS_ORIGIN=https://remindarr.example.com,https://www.remindarr.example.com

# ── TMDB ────────────────────────────────────────────────────────────────────
# TMDB_COUNTRY=HR                # ISO-3166-1 alpha-2 (watch providers scope)
# TMDB_LANGUAGE=en               # ISO-639-1
# TMDB_FALLBACK_COUNTRIES=       # Comma-separated countries to fall back to
# TMDB_API_TIMEOUT_MS=15000

# ── Auth (better-auth) ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Without this, all sessions invalidate on every restart.
BETTER_AUTH_SECRET=

# Optional admin bootstrap password. If unset, a random password is generated
# on first launch and written to `admin-password.txt` next to the DB.
# ADMIN_BOOTSTRAP_PASSWORD=

# ── Passkeys (WebAuthn) ─────────────────────────────────────────────────────
# Leave empty to derive from BASE_URL.
# PASSKEY_RP_ID=remindarr.example.com
# PASSKEY_RP_NAME=Remindarr
# PASSKEY_ORIGIN=https://remindarr.example.com

# ── OIDC (env vars take precedence over admin-UI settings) ──────────────────
# OIDC_ISSUER_URL=https://id.example.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=https://remindarr.example.com/api/auth/callback/pocketid
# OIDC_ADMIN_CLAIM=groups        # JWT claim that carries admin membership
# OIDC_ADMIN_VALUE=admin         # Required value of the admin claim

# ── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# ── Sentry (optional) ───────────────────────────────────────────────────────
# Server DSN — Bun deploys use remindarr-be, CF Workers use remindarr-cf.
# SENTRY_DSN=
# Frontend DSN — remindarr-fe project. Baked into the bundle at build time
# (Vite loads from .env / .env.production at repo root).
# VITE_SENTRY_DSN=

# ── Prometheus metrics (optional) ───────────────────────────────────────────
# If set, /metrics requires `Authorization: Bearer <token>`.
# If unset, /metrics is public (protect via reverse proxy).
# METRICS_TOKEN=

# ── Cache ───────────────────────────────────────────────────────────────────
# CACHE_BACKEND=memory           # memory | redis | kv (CF only)
# REDIS_URL=redis://localhost:6379
# CACHE_TTL_GENRES=86400
# CACHE_TTL_PROVIDERS=86400
# CACHE_TTL_LANGUAGES=86400
# CACHE_TTL_SEARCH=300
# CACHE_TTL_DETAILS=3600
# CACHE_TTL_BROWSE=900
# CACHE_TTL_STREAMING=86400
# CACHE_MAX_MEMORY_ENTRIES=1000

# ── Scheduled jobs (cron expressions, 5-field) ──────────────────────────────
# SYNC_TITLES_CRON=0 3 * * *
# SYNC_EPISODES_CRON=30 3 * * *
# SYNC_DEEP_LINKS_CRON=0 4 * * *
# SYNC_PLEX_CRON=0 5 * * *
# SYNC_PLEX_LIBRARY_CRON=0 6 * * *
# BACKUP_CRON=0 2 * * *
# BACKUP_RETAIN=7                # Number of backups to keep
# BACKUP_DIR=                    # Empty disables backups

# ── Streaming deep links (optional) ─────────────────────────────────────────
# STREAMING_AVAILABILITY_API_KEY=

# ── Plex ────────────────────────────────────────────────────────────────────
# PLEX_CLIENT_ID=remindarr-plex-client
