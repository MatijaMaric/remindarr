{
  "name": "remindarr",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:frontend\"",
    "dev:server": "bun run --watch server/index.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "build": "cd frontend && bun run build",
    "start": "bun run server/index.ts",
    "sync": "bun run server/cli/sync.ts",
    "check": "bunx tsc --noEmit && cd frontend && bunx tsc --noEmit && cd .. && bun test",
    "test": "bun test",
    "test:server": "bun test server/",
    "test:frontend": "bun test frontend/src/",
    "db:generate": "bunx drizzle-kit generate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@sentry/bun": "^10.43.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.4.0"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^20.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "shadcn": "^4.0.3"
  }
}
